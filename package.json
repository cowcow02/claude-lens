{
  "name": "claude-lens-workspace",
  "version": "0.6.1",
  "private": true,
  "description": "Claude Lens — local-only dashboard for Claude Code sessions. Heatmaps, timelines, parallel agent detection, PR metrics, and Ask Claude analysis.",
  "license": "MIT",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "version": "node scripts/version-sync.mjs && git add packages/*/package.json apps/*/package.json",
    "smoke": "node scripts/smoke.mjs",
    "verify": "pnpm typecheck && pnpm smoke",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "globals": "^17.5.0",
    "prettier": "^3.2.5",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
