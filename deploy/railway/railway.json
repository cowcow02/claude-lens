{
  "$schema": "https://railway.com/railway.schema.json",
  "services": [
    {
      "name": "fleetlens-team-server",
      "build": {
        "dockerfilePath": "packages/team-server/Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE"
      },
      "networking": {
        "servicePort": 3322
      }
    },
    {
      "name": "postgres",
      "image": "postgres:17",
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      },
      "variables": {
        "POSTGRES_DB": "fleetlens",
        "POSTGRES_USER": "fleetlens",
        "POSTGRES_PASSWORD": {
          "generator": "secret"
        }
      },
      "volumes": [
        {
          "mountPath": "/var/lib/postgresql/data"
        }
      ]
    }
  ]
}
